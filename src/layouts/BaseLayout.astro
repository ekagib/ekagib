---
interface Props {
  pageTitle: string;
}
const { pageTitle } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/favicon.ico" />
    <title>{pageTitle}</title>
  </head>

  <body>
    <slot />
  </body>
</html>
